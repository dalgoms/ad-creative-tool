# ──────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────

# PostgreSQL connection string (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/ad_creative_tool?sslmode=require"

# ──────────────────────────────────────────
# OPTIONAL — Copy Generation
# ──────────────────────────────────────────

# When set, uses GPT-4o for copy generation. Falls back to deterministic templates if missing.
OPENAI_API_KEY=""

# ──────────────────────────────────────────
# OPTIONAL — Cloud Storage (Supabase)
# ──────────────────────────────────────────

# When both are set, assets upload to Supabase Storage instead of local filesystem.
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ──────────────────────────────────────────
# OPTIONAL — Make.com Webhook Integration
# ──────────────────────────────────────────

# Shared secret for inbound Make.com webhooks. If set, all incoming requests must include
# the header x-webhook-secret with this value.
MAKE_WEBHOOK_SECRET=""
